{
  "name": "game-sims",
  "version": "1.0.0",
  "private": true,
  "description": "Re-runnable balance simulation harnesses for the games/ prototypes",
  "scripts": {
    "start": "node dungeondeal-sim.js",
    "depths": "node depths-sim.js",
    "loopline": "node loopline-sim.js",
    "swarm": "node swarm-sim.js",
    "swarm:smoke": "node swarm-sim.js 1",
    "swarm:mechanics": "node swarm-sim.js --mechanics",
    "warband": "node warband-sim.js",
    "warband:mechanics": "node warband-sim.js --mechanics",
    "check:syntax": "node check-syntax.js",
    "test": "npm run check:syntax && npm run warband:mechanics && npm run swarm:smoke && npm run swarm:mechanics"
  },
  "dependencies": {
    "jsdom": "^27.0.1"
  }
}
